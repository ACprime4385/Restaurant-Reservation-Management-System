{
  "name": "restaurant-reservation-api",
  "version": "1.0.0",
  "description": "Restaurant reservation API",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
